# Cloudflare Pages — Custom Headers
# Documentation : https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), microphone=(self), camera=(self), payment=(self)
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  # NOTE CSP : une Content-Security-Policy stricte a été RETIRÉE ici. L'app charge de
  # nombreuses origines externes (Tailwind CDN, AdSense, Groq, Cloudinary, Wave, green-api,
  # Mux, Stripe…) ; une CSP incomplète bloquait le CDN Tailwind → homepage sans style.
  # La protection anti-clickjacking reste assurée par X-Frame-Options: DENY.
  # À réintroduire plus tard en Content-Security-Policy-Report-Only d'abord, pour collecter
  # la liste complète des origines avant de passer en mode bloquant.

# Service worker doit pouvoir contrôler tout le scope
/sw.js
  Service-Worker-Allowed: /
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Type: application/javascript; charset=utf-8

# Cache long pour les assets statiques
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Pas de cache pour les fonctions API
/api/*
  Cache-Control: no-cache, no-store, must-revalidate
