# Cloudflare Pages — Custom Headers
# Documentation : https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), microphone=(), camera=(), payment=(self)
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://unpkg.com https://www.googletagmanager.com https://www.google-analytics.com https://plausible.io https://*.supabase.co https://cdn.emailjs.com; connect-src 'self' https://*.supabase.co https://*.pages.dev https://api.emailjs.com https://www.google-analytics.com https://plausible.io https://*.paytech.sn https://api.imgbb.com https://placehold.co https://stream.mux.com https://storage.googleapis.com https://*.litix.io wss://*.supabase.co; media-src 'self' blob: https://stream.mux.com; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# Service worker doit pouvoir contrôler tout le scope
/sw.js
  Service-Worker-Allowed: /
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Type: application/javascript; charset=utf-8

# Cache long pour les assets statiques
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Pas de cache pour les fonctions API
/api/*
  Cache-Control: no-cache, no-store, must-revalidate
