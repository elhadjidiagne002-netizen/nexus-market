{
  "name": "nexus-market-tests",
  "version": "1.0.0",
  "description": "Tests E2E Playwright pour NEXUS Market",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:install": "playwright install chromium",
    "build": "echo Static site",
    "lint": "eslint \"functions/**/*.js\" \"tests/**/*.js\"",
    "format": "prettier --write \"functions/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"functions/**/*.js\" \"tests/**/*.js\"",
    "push": "node push.js",
    "deploy": "node push.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0"
  }
}
