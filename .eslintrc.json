{
  "root": true,
  "env": {
    "browser": true,
    "worker": true,
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "extends": ["eslint:recommended"],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-empty": ["warn", { "allowEmptyCatch": true }],
    "no-console": "off",
    "prefer-const": "warn",
    "eqeqeq": ["warn", "smart"]
  },
  "ignorePatterns": ["node_modules/", "public/index.html", "playwright-report/", "test-results/", ".wrangler/"]
}
