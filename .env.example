# ============================================================
# NEXUS Market Sénégal — Modèle de variables d'environnement
# ------------------------------------------------------------
# Copier ce fichier en `.env` puis renseigner les vraies valeurs.
# NE JAMAIS committer le `.env` réel (déjà couvert par .gitignore).
# Les valeurs ci-dessous sont des PLACEHOLDERS, pas des secrets.
# ============================================================

# ── SERVEUR ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── URLS ─────────────────────────────────────────────────────
FRONTEND_URL=https://votre-frontend.example
BACKEND_URL=https://votre-backend.example

# ── SUPABASE ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...your_anon_key
SUPABASE_SERVICE_KEY=eyJ...your_service_role_key

# ── PROXY IMAGE / IMAGOR (optionnel) ─────────────────────────
# Le proxy /img/:path (functions/img/[[path]].js) sert les images du bucket
# nexus-images via le cache Cloudflare (coupe l'égress Supabase). SANS variable
# ci-dessous : sert l'original mis en cache. AVEC Imagor (self-hosted, Docker :
# github.com/cshum/imagor) : conversion WebP/AVIF + redimensionnement à la volée
# via /img/:path?w=800&h=0&fmt=webp&q=80.
IMAGOR_BASE_URL=            # ex: https://nexus-imagor.onrender.com (SANS slash final)
IMAGOR_SECRET=             # signature thumbor HMAC-SHA1 ; vide → Imagor doit tourner en IMAGOR_UNSAFE=1

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_me_64_hex_chars
JWT_EXPIRES_IN=604800
# [NETTOYAGE] Les vars de refresh token custom (JWT_ACCESS_EXPIRES,
# JWT_REFRESH_EXPIRES, REFRESH_TOKEN_SECRET) et la table refresh_tokens ont été
# retirées : Supabase Auth gère nativement la rotation des tokens (cf. CLAUDE.md).

# ── STRIPE ────────────────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
# Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── PAYTECH (mobile money Sénégal) ───────────────────────────
# REQUIS par les webhooks PayTech (sinon « Configuration incomplete »/401).
# Le code accepte PAYTECH_API_SECRET (canonique) OU l'alias PAYTECH_SECRET_KEY.
PAYTECH_API_KEY=
PAYTECH_API_SECRET=

# ── EMAIL (Resend) ───────────────────────────────────────────
# REQUIS par functions/api/_lib/utils.js -> sendEmail().
RESEND_API_KEY=
EMAIL_FROM="NEXUS Market <no-reply@votre-domaine.example>"
ADMIN_EMAIL=admin@votre-domaine.example
# UUID du profil admin (profiles.id) — destinataire des notifications internes
# (ex. nouvelles demandes de retrait). Sans cette valeur, ces notifs échouent.
ADMIN_USER_ID=
# Téléphone admin (format 221XXXXXXXXX ou local) — optionnel. Si renseigné,
# les événements admin (notify-admin.js : admin_new_vendor, admin_new_dispute,
# admin_payout_request) partent aussi en WhatsApp, en plus de ADMIN_EMAIL.
ADMIN_PHONE=

# ── EMAILJS (optionnel, côté client) ─────────────────────────
EMAILJS_SERVICE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
EMAILJS_TEMPLATE_ORDER=
EMAILJS_TEMPLATE_RESET=

# ── EMAIL SMTP (optionnel, fallback) ─────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="NEXUS Market <no-reply@votre-domaine.example>"

# ── URL CONFIRMATION EMAIL ────────────────────────────────────
CONFIRM_EMAIL_URL=https://votre-frontend.example

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,https://votre-frontend.example
LOG_LEVEL=info

# ── NOTIFICATIONS PUSH VAPID ─────────────────────────────────
# Générer avec : npx web-push generate-vapid-keys
# Ne JAMAIS changer après déploiement (invalide les abonnements existants).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@votre-domaine.example

# ── TRAÇABILITÉ LIVRAISON ────────────────────────────────────
SENPOST_API_KEY=""
GIG_API_KEY=""
DHL_API_KEY=""
CARRIER_WEBHOOK_BASE_URL=https://votre-frontend.example

# ── GROQ AI (Assistant IA) ───────────────────────────────────
GROQ_API_KEY=gsk_xxx
GROQ_MODEL=llama-3.3-70b-versatile

# ── Sécurité paiement (anti sous-paiement) ───────────────────
# Remise maximale tolérée entre le montant payé et le total réel de la commande
# (0.6 = 60 %). En-dessous de ce plancher, l'initiation/confirmation du paiement
# est refusée (protège contre « payer 1 000 FCFA pour 500 000 »). Voir
# functions/api/_lib/utils.js → validatePaymentAmount.
PAY_MAX_DISCOUNT=0.6
# Taux EUR→XOF utilisé pour comparer amount (XOF, PayTech) à orders.total (EUR).
EUR_TO_XOF=655.957

# ── Sécurité appels internes & CORS ──────────────────────────
# Secret partagé pour les appels SERVEUR→SERVEUR (webhooks/cron → /push-send,
# /api/whatsapp, /api/email/send). En-tête X-Internal-Secret. NE JAMAIS exposer
# côté client. À défaut, repli sur CRON_SECRET.
INTERNAL_API_SECRET=change-me-long-random-server-only
# Origines autorisées pour le CORS credentialed (séparées par des virgules).
# Les sous-domaines *.pages.dev et localhost sont déjà autorisés par défaut.
ALLOWED_ORIGINS=https://nexus-market-asb.pages.dev,https://nexus.sn
