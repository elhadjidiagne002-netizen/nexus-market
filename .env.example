# ============================================================
# NEXUS Market Sénégal — Modèle de variables d'environnement
# ------------------------------------------------------------
# Copier ce fichier en `.env` puis renseigner les vraies valeurs.
# NE JAMAIS committer le `.env` réel (déjà couvert par .gitignore).
# Les valeurs ci-dessous sont des PLACEHOLDERS, pas des secrets.
# ============================================================

# ── SERVEUR ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── URLS ─────────────────────────────────────────────────────
FRONTEND_URL=https://votre-frontend.example
BACKEND_URL=https://votre-backend.example

# ── SUPABASE ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...your_anon_key
SUPABASE_SERVICE_KEY=eyJ...your_service_role_key

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_me_64_hex_chars
JWT_EXPIRES_IN=604800

# ── JWT REFRESH TOKEN ────────────────────────────────────────
JWT_ACCESS_EXPIRES=900
JWT_REFRESH_EXPIRES=2592000
REFRESH_TOKEN_SECRET=change_me_128_hex_chars

# ── STRIPE ────────────────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
# Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── PAYTECH (mobile money Sénégal) ───────────────────────────
# REQUIS par les webhooks PayTech (sinon « Configuration incomplete »/401).
# Le code accepte PAYTECH_API_SECRET (canonique) OU l'alias PAYTECH_SECRET_KEY.
PAYTECH_API_KEY=
PAYTECH_API_SECRET=

# ── EMAIL (Resend) ───────────────────────────────────────────
# REQUIS par functions/api/_lib/utils.js -> sendEmail().
RESEND_API_KEY=
EMAIL_FROM="NEXUS Market <no-reply@votre-domaine.example>"
ADMIN_EMAIL=admin@votre-domaine.example
# UUID du profil admin (profiles.id) — destinataire des notifications internes
# (ex. nouvelles demandes de retrait). Sans cette valeur, ces notifs échouent.
ADMIN_USER_ID=

# ── EMAILJS (optionnel, côté client) ─────────────────────────
EMAILJS_SERVICE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
EMAILJS_TEMPLATE_ORDER=
EMAILJS_TEMPLATE_RESET=

# ── EMAIL SMTP (optionnel, fallback) ─────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="NEXUS Market <no-reply@votre-domaine.example>"

# ── URL CONFIRMATION EMAIL ────────────────────────────────────
CONFIRM_EMAIL_URL=https://votre-frontend.example

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,https://votre-frontend.example
LOG_LEVEL=info

# ── NOTIFICATIONS PUSH VAPID ─────────────────────────────────
# Générer avec : npx web-push generate-vapid-keys
# Ne JAMAIS changer après déploiement (invalide les abonnements existants).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@votre-domaine.example

# ── TRAÇABILITÉ LIVRAISON ────────────────────────────────────
SENPOST_API_KEY=""
GIG_API_KEY=""
DHL_API_KEY=""
CARRIER_WEBHOOK_BASE_URL=https://votre-frontend.example

# ── GROQ AI (Assistant IA) ───────────────────────────────────
GROQ_API_KEY=gsk_xxx
GROQ_MODEL=llama-3.3-70b-versatile
